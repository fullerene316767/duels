local function renderTab(tabName)
	-- clear content
	for _, r in ipairs(currentRows) do r:Destroy() end
	currentRows = {}
	ContentLabel.Text = tabName

	local features = tabData[tabName]
	for i, feat in ipairs(features) do
		local row = createToggleRow(feat, tabName, i)
		table.insert(currentRows, row)
	end

	-- update sidebar highlights
	for name, btn in pairs(sidebarBtns) do
		if name == tabName then
			btn.BackgroundColor3 = BG_PANEL
			btn.TextColor3 = LEMON
			btn.Font = Enum.Font.GothamBold
		else
			btn.BackgroundColor3 = Color3.fromRGB(0,0,0,0)
			btn.BackgroundTransparency = 1
			btn.TextColor3 = TEXT_OFF
			btn.Font = Enum.Font.Gotham
		end
	end
end

